---
layout: none
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
<channel>
<title>景一·寓言城堡</title>
<description>从人性出发，自然穿透所有领域。72支柱·600+篇冶炼。</description>
<link>{{ site.url }}{{ site.baseurl }}</link>
<atom:link href="{{ site.url }}{{ site.baseurl }}/feed.xml" rel="self" type="application/rss+xml"/>
<language>zh-CN</language>
<lastBuildDate>{{ site.time | date_to_rfc822 }}</lastBuildDate>
{% assign articles = site.pages | where_exp: "p", "p.path contains '02-知识图谱'" | sort: "date" | reverse %}
{% for page in articles limit:30 %}
<item>
<title>{{ page.title | default: page.name }}</title>
<link>{{ site.url }}{{ site.baseurl }}{{ page.url }}</link>
<description>{{ page.content | strip_html | truncate: 200 }}</description>
<pubDate>{{ page.date | date_to_rfc822 }}</pubDate>
<guid>{{ site.url }}{{ site.baseurl }}{{ page.url }}</guid>
</item>
{% endfor %}
</channel>
</rss>
